# ===================================================
# KINFIGURASI X/TWITTER SCRAPER
# ===================================================

# Target akun X yang mau di-monitor (dipisah koma)
TARGET_ACCOUNTS=elonmusk,cryptoanalyst,whale_alert

# Filter: hanya abbil tweet dengan keyword ini (kosongkan untuk semua)
FILTER_KEYWORDS=

# Skip replies dan retweets
SKIP_REPLIES=true
SKIP_RETWEETS=true

# ===================================================
# KINFIGURASI WAHA WHATSAPP
# ===================================================

# URL WAHA server
WAHA_URL=http://localhost:3000

# Session name di WAHA
WAHA_SESSION=default

# Channel ID WhatsApp (format: 123456789@newsletter)
# Cara dapat: buka channel di WA > Info > copy dari invite link
WAHA_CHANNEL_ID=123456789@newsletter

# ===================================================
# BOT SETTINGS
# ===================================================

# Check interval dalam menit (minimal 5)
CHECK_INTERVAL_MINUTES=5

# Delay antar pesan ke WA (dalam ms, minimal 5000)
MESSAGE_DELAY_MS=5000

# Jumlah tweet max per check per akun
MAX_TWEETS_PER_CHECK=5

# Headless browser (true untuk production, false untuk debugging)
HEADLESS=true
